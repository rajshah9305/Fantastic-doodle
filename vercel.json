{
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "framework": null,
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/trpc/:path*",
      "destination": "/api/trpc"
    }
  ],
  "functions": {
    "api/trpc.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
