{
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install --no-frozen-lockfile && cd api && pnpm install && cd ..",
  "framework": null,
  "outputDirectory": "dist/public",
  "crons": [],
  "rewrites": [
    {
      "source": "/api/trpc/:path*",
      "destination": "/api/trpc"
    }
  ],
  "functions": {
    "api/trpc.js": {
      "memory": 1024,
      "maxDuration": 30,
      "runtime": "nodejs20.x"
    }
  }
}
