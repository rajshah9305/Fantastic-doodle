# Vercel Environment Configuration

# The base URL of the deployed application
VERCEL_URL=https://<your-deployment-url>.vercel.app
# Example: VERCEL_URL=https://fantastic-doodle.vercel.app

# API key for accessing any external services (replace with your service's API key)
API_KEY=your_api_key_here
# Example: API_KEY=12345

# The database connection string (if applicable)
DATABASE_URL=your_database_connection_string_here
# Example: DATABASE_URL=mysql://user:password@host:port/database

# Secret key for JWT authentication purposes
JWT_SECRET=your_jwt_secret_here
# Example: JWT_SECRET=supersecretkey123

# Environment name (e.g., production, staging)
NODE_ENV=production
# Example: NODE_ENV=development

# Other environment-specific variables can go here
CUSTOM_VARIABLE=your_custom_value
# Example: CUSTOM_VARIABLE=some_value
