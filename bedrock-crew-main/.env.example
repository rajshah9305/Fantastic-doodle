# Universal NLP Interface - Environment Variables
# Copy this file to .env and update with your values

# ============================================
# BACKEND CONFIGURATION (backend/.env)
# ============================================

# Environment mode
ENVIRONMENT=development

# API server configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS origins (comma-separated)
# For production, use your actual domain
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_PER_MINUTE=20

# Default Groq model
# Options: llama-3.3-70b-versatile, llama-3.1-70b-versatile, 
#          llama-3.1-8b-instant, mixtral-8x7b-32768, gemma2-9b-it
DEFAULT_GROQ_MODEL=llama-3.3-70b-versatile

# Logging level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================
# FRONTEND CONFIGURATION (frontend/.env)
# ============================================

# Backend API URL
# Leave empty for auto-detection in production
# For local development: http://localhost:8000
VITE_API_URL=http://localhost:8000

# ============================================
# GROQ API (Optional - can be entered in UI)
# ============================================

# Your Groq API key (starts with gsk_)
# Get one free at: https://console.groq.com
# GROQ_API_KEY=gsk_your_key_here

# ============================================
# PRODUCTION NOTES
# ============================================

# For Vercel deployment:
# 1. Set CORS_ORIGINS to your Vercel URL
# 2. Set ENVIRONMENT to "production"
# 3. VITE_API_URL can be left empty (auto-detects)
# 4. GROQ_API_KEY is optional (users can enter in UI)

# Example production values:
# ENVIRONMENT=production
# CORS_ORIGINS=https://your-app.vercel.app
# VITE_API_URL=https://your-app.vercel.app
